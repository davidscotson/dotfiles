[core]
    pager = delta
    editor = nvim
#    fsmonitor = .git/hooks/fsmonitor-watchman
[user]
    name = David Scotson
    email = david.scotson@gmail.com
[merge]
    ff = only
    conflictstyle = zdiff3
    tool = nvimdiff1
[mergetool]
  prompt = false
[pull]
    ff = only
[difftool]
    prompt = false
[diff]
    colorMoved = dimmed-zebra
    tool = nvimdiff
[init]
    defaultBranch = main
[interactive]
    diffFilter = delta --color-only
[feature]
    manyFiles = true
[rebase]
    autosquash = true
    autostash = true
[push]
    autoSetupRemote = true
[rerere]
    enabled = true
[fetch]
    prune = true
[commit]
    verbose = true
[branch]
    sort = -committerdate
[delta]
    navigate = true
    syntax-theme = Monokai Extended Origin
    side-by-side = true
    dark = true
    hyperlinks = true
